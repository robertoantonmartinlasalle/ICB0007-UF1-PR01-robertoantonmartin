<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Campo para el nombre del cohete -->
    <EditText
        android:id="@+id/etRocketName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nombre del cohete"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Campo para la descripción -->
    <EditText
        android:id="@+id/etRocketDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Descripción"
        app:layout_constraintTop_toBottomOf="@id/etRocketName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Campo para el tipo -->
    <EditText
        android:id="@+id/etRocketType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Tipo del cohete"
        app:layout_constraintTop_toBottomOf="@id/etRocketDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Campo para el país -->
    <EditText
        android:id="@+id/etRocketCountry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="País"
        app:layout_constraintTop_toBottomOf="@id/etRocketType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Campo para la empresa -->
    <EditText
        android:id="@+id/etRocketCompany"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Empresa"
        app:layout_constraintTop_toBottomOf="@id/etRocketCountry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Campo para el costo por lanzamiento -->
    <EditText
        android:id="@+id/etRocketCost"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Costo por lanzamiento (USD)"
        app:layout_constraintTop_toBottomOf="@id/etRocketCompany"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Campo para el porcentaje de éxito -->
    <EditText
        android:id="@+id/etRocketSuccessRate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Porcentaje de éxito (%)"
        app:layout_constraintTop_toBottomOf="@id/etRocketCost"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Botón para guardar -->
    <Button
        android:id="@+id/btnSaveRocket"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardar"
        app:layout_constraintTop_toBottomOf="@id/etRocketSuccessRate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
