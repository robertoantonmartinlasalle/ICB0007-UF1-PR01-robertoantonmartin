<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/rocketListFragment">

    <!-- Fragmento para la lista de cohetes -->
    <fragment
        android:id="@+id/rocketListFragment"
        android:name="com.icb0007_uf1_pr01_robertoanton.RocketListFragment"
        android:label="Lista de Cohetes">
        <!-- Acción para navegar al fragmento de detalles -->
        <action
            android:id="@+id/action_rocketListFragment_to_rocketDetailFragment"
            app:destination="@id/rocketDetailFragment" />
        <!-- Acción para navegar al fragmento de crear cohete -->
        <action
            android:id="@+id/action_rocketListFragment_to_createRocketFragment"
            app:destination="@id/createRocketFragment" />
    </fragment>

    <!-- Fragmento para los detalles de un cohete -->
    <fragment
        android:id="@+id/rocketDetailFragment"
        android:name="com.icb0007_uf1_pr01_robertoanton.RocketDetailFragment"
        android:label="Detalles del Cohete">
        <!-- Argumento para pasar el objeto Rocket -->
        <argument
            android:name="rocket"
            app:argType="com.icb0007_uf1_pr01_robertoanton.Rocket" />
    </fragment>

    <!-- Fragmento para crear un nuevo cohete -->
    <fragment
        android:id="@+id/createRocketFragment"
        android:name="com.icb0007_uf1_pr01_robertoanton.CreateRocketFragment"
        android:label="Crear Cohete" />
</navigation>
